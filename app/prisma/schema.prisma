generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Cliente {
  id        String   @id @default(cuid())
  nome      String
  email     String   @unique
  telefono  String?
  azienda   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  offerte   Offerta[]
}

model Prodotto {
  id          String   @id @default(cuid())
  codice      String   @unique
  nome        String
  descrizione String?
  prezzo      Decimal  @db.Decimal(10, 2)
  unita       String   @default("pz")
  attivo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  righe       RigaOfferta[]
}

model Offerta {
  id          String        @id @default(cuid())
  numero      String        @unique
  titolo      String
  stato       StatoOfferta  @default(BOZZA)
  clienteId   String
  cliente     Cliente       @relation(fields: [clienteId], references: [id])
  righe       RigaOfferta[]
  note        String?
  validaFino  DateTime?
  totale      Decimal       @default(0) @db.Decimal(10, 2)
  sconto      Decimal       @default(0) @db.Decimal(5, 2)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model RigaOfferta {
  id          String   @id @default(cuid())
  offertaId   String
  offerta     Offerta  @relation(fields: [offertaId], references: [id], onDelete: Cascade)
  prodottoId  String
  prodotto    Prodotto @relation(fields: [prodottoId], references: [id])
  quantita    Decimal  @db.Decimal(10, 3)
  prezzoUnit  Decimal  @db.Decimal(10, 2)
  sconto      Decimal  @default(0) @db.Decimal(5, 2)
  totale      Decimal  @db.Decimal(10, 2)
  note        String?
  ordine      Int      @default(0)
}

enum StatoOfferta {
  BOZZA
  INVIATA
  ACCETTATA
  RIFIUTATA
  SCADUTA
}
